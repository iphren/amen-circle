generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  OPEN
  CLOSED
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())

  // Consent records (UK GDPR): nullable because rows predating the consent
  // flow exist; those users are gated in-app until they accept (ConsentGate).
  // religiousDataConsentAt is the Art. 9(2)(a) explicit consent for prayer
  // content and is deliberately separate from terms acceptance (unbundled).
  termsAcceptedAt        DateTime?
  religiousDataConsentAt DateTime?
  ageConfirmedAt         DateTime?

  // Set when the user proves ownership of their email by consuming an emailed
  // single-use token (sign-in or registration link). A zero-passkey row with
  // this set is a real account, NOT a resumable interrupted signup.
  emailVerifiedAt DateTime?

  // Preferred UI language (e.g. "en-GB", "zh-CN). Null means "not set" — the
  // app then detects from the browser. Stored here so the choice syncs across
  // the user's devices.
  preferredLanguage String?

  passkeys         Passkey[]
  recoveryTokens   RecoveryToken[]
  loginTokens      LoginToken[]
  memberships      Membership[]
  ownedRooms       PrayerRoom[]    @relation("RoomOwner")
  authoredRequests PrayerRequest[] @relation("RequestAuthor")
  assignedRequests PrayerRequest[] @relation("RequestAssignee")
}

model RecoveryToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha-256 hex of the raw token; the raw token is never stored
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model LoginToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha-256 hex of the raw token; the raw token is never stored
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Passkey {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  deviceType   String
  backedUp     Boolean
  transports   String[]
  name         String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model PrayerRoom {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  ownerId   String
  owner     User       @relation("RoomOwner", fields: [ownerId], references: [id])
  status    RoomStatus @default(OPEN)
  createdAt DateTime   @default(now())
  closedAt  DateTime?

  memberships Membership[]
  requests    PrayerRequest[]

  @@index([ownerId])
}

model Membership {
  id       String     @id @default(cuid())
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId   String
  room     PrayerRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  joinedAt DateTime   @default(now())

  @@unique([userId, roomId])
  @@index([roomId])
}

model PrayerRequest {
  id             String     @id @default(cuid())
  roomId         String
  room           PrayerRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId       String
  author         User       @relation("RequestAuthor", fields: [authorId], references: [id])
  assignedToId   String?
  assignedTo     User?      @relation("RequestAssignee", fields: [assignedToId], references: [id])
  content        String
  isConfidential Boolean    @default(false)
  createdAt      DateTime   @default(now())
  prayedAt       DateTime?
  // Set by the author ("prayer answered"); shown to the assignee as
  // encouragement. Non-identifying in both directions.
  answeredAt     DateTime?

  @@index([roomId])
  @@index([authorId])
  @@index([assignedToId])
}
